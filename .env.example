# Distil - variables d'environnement
# Copier en .env.local pour dev, injecter via Netlify UI pour prod.
# Tous les fichiers .env* sont gitignores ; pour tracker ce template,
# ajouter "!.env.example" dans .gitignore.

# === Supabase (requis) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === LLM providers ===
# Gemini requis (ranking + scoring + profile-generator)
GOOGLE_AI_API_KEY=

# === Embeddings (requis pour ranking vectoriel) ===
VOYAGE_API_KEY=

# === App URL (requis pour crons, emails, bookmarklet) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Crons (requis pour tous les endpoints /api/cron/*) ===
CRON_SECRET=
# Optionnel : utilise pour les tokens unsubscribe HMAC.
# Si absent, fallback sur CRON_SECRET (coupling a eviter en prod).
UNSUBSCRIBE_SECRET=

# === Email digest (requis si digest_email active) ===
RESEND_API_KEY=
# Optionnel, defaut "Distil <digest@distil.app>"
RESEND_FROM=

# === Web push notifications (optionnel) ===
# Generer avec : pnpm exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# === Admin (requis pour /api/admin/*) ===
ADMIN_TOKEN=

# === Dev only ===
# Bypasse l'auth en local (NODE_ENV=development uniquement)
DEV_BYPASS_AUTH=false

# === Netlify (optionnel) ===
# Hook webhook pour trigger manuel d'un deploy
NETLIFY_DEPLOY_HOOK=

# === Mode lecture (PR-07) ===
# Ratio d'extrait affiche en mode lecture (strategie Option B : on renvoie a la source).
# Defaut 0.3. Plafond dur 0.5 applique dans le code, cette valeur n'agit que sous ce plafond.
ARTICLE_EXTRACT_RATIO=0.3
# Plancher minimum en mots pour ne pas produire un extrait inutilement court
# sur les articles de moyenne taille. Defaut 150.
ARTICLE_EXTRACT_MIN_WORDS=150
